{
  "name": "@starnever0/openclaw-cognix-plugin",
  "version": "1.0.0",
  "description": "OpenClaw memory plugin using Cognix (self-hosted)",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "build": "esbuild index.ts --bundle --platform=node --format=esm --outfile=index.js --external:openclaw --external:@sinclair/typebox",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.48"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.0.0"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "minHostVersion": ">=2026.3.22"
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
